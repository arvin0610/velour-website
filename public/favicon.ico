border-[color:var(--line-dark)] bg-white/70 p-1.5 pl-5"><input type="email" placeholder="researcher@institution.edu" class="flex-1 bg-transparent text-sm text-[color:var(--porcelain)] placeholder:text-[color:var(--slate)] focus:outline-none"/><button type="submit" class="btn btn-primary text-[0.8rem]">Keep me posted</button></form></div></div><hr class="hairline my-14"/><div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4"><div><p class="eyebrow">Catalog</p><ul class="mt-5 space-y-3"><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/shop">All materials</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/shop?cat=repair">Tissue pathways</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/shop?cat=gh-axis">Growth-hormone research</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/shop?cat=metabolic">Metabolic pathways</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/shop?cat=longevity">Aging biology</a></li></ul></div><div><p class="eyebrow">Documentation</p><ul class="mt-5 space-y-3"><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/quality">Quality standards</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/coas">COA library</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/research">Research notes</a></li><li><a class="text-sm text-[color:var(--graphite)] transition-colors hover:text-[color:var(--champagne)]" href="/about">About Velour</a></li></ul></div><div><p class="eyebrow">Support</p><ul class="mt-5 space-y-3"><li><a clas