# Normalize text to LF in the repo; never apply CRLF munging to binaries.
* text=auto eol=lf

# Binary assets — never run through line-ending or diff filters.
*.jpg   binary
*.jpeg  binary
*.png   binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
